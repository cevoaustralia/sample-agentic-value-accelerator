.bedrock_agentcore.yaml
.bedrock_agentcore/

# Ignore Docker build artifacts but keep docker/ directory structure
docker/**/*.tar.gz
docker/**/*.zip
docker/**/build/
docker/**/dist/

# Amplify deployment artifacts
**/deploy.zip
*.pkg
platform/ui/testing-dashboard/src/App.dynamo.js
platform/ui/testing-dashboard/src/App.dynamo.js

# Terraform state files (contain sensitive data)
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl
terraform.tfstate.d/

# Internal (not for public release)
internal/

# Claude and development tool directories
.claude/
**/.claude/
.omc/
**/.omc/
.context/
**/.context/
.patent/
**/.patent/
.scan_reports/
**/.scan_reports/
.hypothesis/
.kiro/
.tests/
.worktrees/

# Node.js
node_modules/
**/node_modules/
dist/
**/dist/

# AWS Icon source package (icons already copied to each UI's public/aws-icons/)
Icon-package_*/

# macOS
.DS_Store
**/.DS_Store

