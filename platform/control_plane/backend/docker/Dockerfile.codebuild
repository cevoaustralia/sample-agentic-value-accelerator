# Dockerfile.codebuild — CodeBuild Docker image for IaC execution.
# Includes Terraform 1.5+, AWS CLI v2, Python 3.11, Node.js, aws-cdk, Docker, jq.
FROM public.ecr.aws/amazonlinux/amazonlinux:2023

# Install system packages and Python 3.11
RUN yum update -y && \
    yum install -y \
      yum-utils \
      unzip \
      jq \
      tar \
      gzip \
      git \
      python3.11 \
      python3.11-pip \
      docker \
    && yum clean all && \
    rm -rf /var/cache/yum

# Install Terraform 1.5+ from HashiCorp repo
RUN yum-config-manager --add-repo https://rpm.releases.hashicorp.com/AmazonLinux/hashicorp.repo && \
    yum install -y terraform && \
    yum clean all && \
    rm -rf /var/cache/yum

# Install AWS CLI v2
RUN curl -s "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o "awscliv2.zip" && \
    unzip -q awscliv2.zip && \
    ./aws/install && \
    rm -rf awscliv2.zip aws

# Install Node.js (LTS) and aws-cdk
RUN curl -fsSL https://rpm.nodesource.com/setup_20.x | bash - && \
    yum install -y nodejs && \
    yum clean all && \
    rm -rf /var/cache/yum && \
    npm install -g aws-cdk

# Set Python 3.11 as default
RUN alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1 && \
    alternatives --install /usr/bin/pip3 pip3 /usr/bin/pip3.11 1

# Copy executor scripts and make executable
COPY scripts/ /opt/scripts/
RUN chmod +x /opt/scripts/*.sh

# Create output directory for build artifacts
RUN mkdir -p /codebuild/output

ENTRYPOINT ["/bin/bash"]
