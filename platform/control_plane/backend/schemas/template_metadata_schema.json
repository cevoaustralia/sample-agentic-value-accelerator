{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ava/control-plane/template-metadata.schema.json",
  "title": "Template Metadata Schema",
  "description": "Schema for Control Plane template metadata (template.json)",
  "type": "object",
  "required": [
    "id",
    "name",
    "description",
    "version",
    "pattern_type"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "minLength": 3,
      "maxLength": 50,
      "description": "Unique template identifier (lowercase, alphanumeric, hyphens)"
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 100,
      "description": "Human-readable template name"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 1000,
      "description": "Detailed description of the template and pattern"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$",
      "description": "Semantic version (e.g., 1.0.0)"
    },
    "pattern_type": {
      "type": "string",
      "enum": [
        "single_agent",
        "orchestration",
        "rag",
        "tool_calling",
        "conversational",
        "batch_processing"
      ],
      "description": "Architectural pattern category"
    },
    "frameworks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "path"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "description": "Framework identifier (lowercase, alphanumeric, underscores)"
          },
          "name": {
            "type": "string",
            "description": "Human-readable framework name"
          },
          "path": {
            "type": "string",
            "pattern": "^src/[a-z][a-z0-9_]*$",
            "description": "Relative path to framework code (e.g., src/langchain_langgraph)"
          },
          "description": {
            "type": "string",
            "description": "Optional framework description"
          }
        }
      },
      "description": "Supported agent frameworks"
    },
    "deployment_patterns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "path"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "description": "Pattern identifier (lowercase, alphanumeric, underscores)"
          },
          "name": {
            "type": "string",
            "description": "Human-readable pattern name"
          },
          "description": {
            "type": "string",
            "description": "Pattern description"
          },
          "path": {
            "type": "string",
            "pattern": "^iac/[a-z][a-z0-9_]*$",
            "description": "Relative path to IaC code (e.g., iac/terraform)"
          }
        }
      },
      "description": "Supported deployment patterns"
    },
    "parameters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "type",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "description": "Parameter name (lowercase, alphanumeric, underscores)"
          },
          "type": {
            "type": "string",
            "enum": [
              "string",
              "integer",
              "boolean",
              "array",
              "object"
            ],
            "description": "Parameter data type"
          },
          "description": {
            "type": "string",
            "description": "Parameter description"
          },
          "required": {
            "type": "boolean",
            "default": false,
            "description": "Whether parameter is required"
          },
          "default": {
            "description": "Default value if not provided"
          },
          "pattern": {
            "type": "string",
            "description": "Regex pattern for validation (string types only)"
          },
          "minimum": {
            "type": "number",
            "description": "Minimum value (integer types only)"
          },
          "maximum": {
            "type": "number",
            "description": "Maximum value (integer types only)"
          },
          "enum": {
            "type": "array",
            "description": "Allowed values (enumeration)"
          }
        }
      },
      "description": "Template-specific parameters"
    },
    "architecture_diagram": {
      "type": "string",
      "format": "uri",
      "description": "URL or path to architecture diagram"
    },
    "example_use_cases": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of example use cases this pattern enables"
    },
    "author": {
      "type": "string",
      "description": "Template author"
    },
    "license": {
      "type": "string",
      "description": "Template license"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Template tags for categorization"
    },
    "type": {
      "type": "string",
      "enum": [
        "foundation",
        "usecase"
      ],
      "default": "usecase",
      "description": "Template type for layering (foundation or usecase)"
    },
    "outputs": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Output keys this template produces after deployment"
    },
    "jobs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "incoming_event",
          "outgoing_event"
        ],
        "properties": {
          "name": {
            "type": "string",
            "enum": [
              "onboarding",
              "offboarding"
            ]
          },
          "incoming_event": {
            "type": "string",
            "minLength": 1
          },
          "outgoing_event": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "description": "Lifecycle jobs (onboarding, offboarding)"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Foundation template IDs required before this template"
    }
  }
}