# AWS Configuration
aws_region = "us-east-1"
environment = "dev"

# Project Configuration
app_name     = "control-plane"
project_name = "ava"

# VPC Configuration (Optional - leave empty to create new VPC)
# If using existing VPC, provide these values:
# vpc_id             = "vpc-xxxxx"
# public_subnet_ids  = ["subnet-xxxxx", "subnet-yyyyy"]
# private_subnet_ids = ["subnet-aaaaa", "subnet-bbbbb"]

# VPC Configuration (For new VPC creation)
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b"]

# Domain Configuration (Optional)
domain_name    = "ava-platform.example.com"
hosted_zone_id = "" # Leave empty if not using custom domain

# ECS Configuration
ecs_task_cpu       = 512
ecs_task_memory    = 1024
ecs_desired_count  = 2
ecs_min_capacity   = 1
ecs_max_capacity   = 4
container_image    = "" # Will use ECR repository URL

# S3 Configuration
project_archive_retention_days = 7

# Cognito Configuration
cognito_user_pool_name = "control-plane-users"
cognito_enable_mfa     = false

# CodeCommit Configuration (Optional - for Git-based CI/CD)
enable_codecommit                  = false # Set to true to enable CodeCommit repository
codecommit_repository_name         = ""    # Leave empty for auto-generated name
codecommit_repository_description  = "AVA Control Plane CI/CD Source Repository"
codecommit_enable_push_trigger     = true  # Trigger deployments on git push
codecommit_enable_pr_trigger       = true  # Trigger deployments on PR merge
codecommit_trigger_branches        = ["main", "develop"]
codecommit_enable_notifications    = false # Enable SNS notifications for CodeCommit events

# Tags
tags = {
  Project   = "ava"
  Component = "control-plane"
  ManagedBy = "terraform"
}

owner       = "platform-team"
cost_center = "ai-platform"

# Docker Hub credentials (optional)
#
# Required for langfuse foundation-stack deploys against any account that runs
# the demo more than ~once per 6 hours — the langfuse module pulls 3 images
# from docker.io and the anonymous pull cap (100/6hr per source IP) gets
# exhausted by ~the third deploy. Setting these creates a Secrets Manager
# secret named `dockerhub-credentials` that the buildspec auto-detects.
#
# Use a read-only "Public Repos" PAT — that's all the langfuse pulls need.
# Leave both empty to skip; the buildspec falls back to anonymous pulls.
#
# dockerhub_username = "your-dh-username"
# dockerhub_token    = "dckr_pat_xxxxxxxxxxxxxxxxxxxxxxxx"
