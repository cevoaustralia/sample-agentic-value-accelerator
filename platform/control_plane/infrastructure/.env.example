# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# Environment
ENVIRONMENT=dev

# Existing VPC Configuration (leave empty to create new VPC)
# If you have an existing VPC, provide these values to skip VPC creation
VPC_ID=
PUBLIC_SUBNET_IDS=subnet-xxx,subnet-yyy
PRIVATE_SUBNET_IDS=subnet-aaa,subnet-bbb

# Domain Configuration
DOMAIN_NAME=ava-platform.example.com
HOSTED_ZONE_ID=

# Application Configuration
APP_NAME=control-plane
PROJECT_NAME=ava

# ECS Configuration
ECS_TASK_CPU=512
ECS_TASK_MEMORY=1024
ECS_DESIRED_COUNT=2
ECS_MIN_CAPACITY=1
ECS_MAX_CAPACITY=4

# Database Configuration (for future RDS if needed)
DB_INSTANCE_CLASS=db.t3.micro
DB_ALLOCATED_STORAGE=20

# S3 Configuration
PROJECT_ARCHIVE_RETENTION_DAYS=7

# Cognito Configuration
COGNITO_USER_POOL_NAME=control-plane-users
COGNITO_ENABLE_MFA=false

# Tags
OWNER=platform-team
COST_CENTER=ai-platform
