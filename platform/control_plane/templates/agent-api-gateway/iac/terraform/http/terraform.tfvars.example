# =============================================================================
# Agent API Gateway — HTTP Variant
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

project_name     = "my-agent-api"
aws_region       = "us-east-1"
backend_endpoint = "https://your-agentcore-endpoint.example.com"

# -----------------------------------------------------------------------------
# Optional — Environment
# -----------------------------------------------------------------------------

# environment = "dev"  # dev | staging | prod

# -----------------------------------------------------------------------------
# Optional — CORS
# -----------------------------------------------------------------------------

# cors_allow_origins = ["*"]
# cors_allow_methods = ["POST", "GET", "OPTIONS"]
# cors_allow_headers = ["Content-Type", "Authorization", "X-Amz-Date"]

# -----------------------------------------------------------------------------
# Optional — Throttling
# -----------------------------------------------------------------------------

# throttling_burst_limit = 100
# throttling_rate_limit  = 50

# -----------------------------------------------------------------------------
# Optional — Authentication
# -----------------------------------------------------------------------------

# auth_type             = "NONE"  # NONE | JWT | AWS_IAM
# cognito_user_pool_id  = ""      # Required when auth_type = JWT
# cognito_app_client_id = ""      # Required when auth_type = JWT

# -----------------------------------------------------------------------------
# Optional — Custom Domain
# -----------------------------------------------------------------------------

# custom_domain   = ""  # e.g. "api.example.com"
# certificate_arn = ""  # ACM certificate ARN, required with custom_domain

# -----------------------------------------------------------------------------
# Optional — Logging
# -----------------------------------------------------------------------------

# log_retention_days = 30

# -----------------------------------------------------------------------------
# Optional — Additional Tags
# -----------------------------------------------------------------------------

# tags = {
#   Team  = "platform"
#   Owner = "your-alias"
# }
