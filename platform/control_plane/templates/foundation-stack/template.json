{
  "id": "foundation-stack",
  "name": "Foundation Stack \u2014 Langfuse Observability",
  "description": "Deploys Langfuse v3 observability platform on ECS Fargate with Aurora PostgreSQL, ClickHouse, Redis, CloudFront, and VPC networking. Deploy once per account/region \u2014 all agents send traces here.",
  "version": "1.0.0",
  "tier": "infrastructure",
  "category": "observability",
  "type": "foundation",
  "iac_options": [
    "terraform"
  ],
  "includes": {
    "infra": true,
    "agent_code": false,
    "ui": false,
    "tests": false
  },
  "tags": [
    "langfuse",
    "observability",
    "tracing",
    "ecs",
    "aurora",
    "cloudfront",
    "foundation"
  ],
  "aws_services": [
    "ecs",
    "rds",
    "elasticache",
    "cloudfront",
    "alb",
    "s3",
    "ecr",
    "secretsmanager",
    "lambda"
  ],
  "frameworks_list": [],
  "built_with": [],
  "frameworks": [
    {
      "id": "infrastructure",
      "name": "Infrastructure Only",
      "path": "src/infrastructure",
      "description": "No agent framework \u2014 infrastructure only"
    }
  ],
  "deployment_patterns": [
    {
      "id": "terraform",
      "name": "Langfuse on ECS",
      "description": "ECS Fargate with managed Aurora PostgreSQL, ElastiCache Redis, and ClickHouse",
      "path": "iac/terraform"
    }
  ],
  "parameters": [
    {
      "name": "project_name",
      "type": "string",
      "description": "Project name",
      "required": true,
      "default": "foundation"
    },
    {
      "name": "aws_region",
      "type": "string",
      "description": "AWS region",
      "required": false,
      "default": "us-east-1"
    },
    {
      "name": "langfuse_admin_email",
      "type": "string",
      "description": "Langfuse admin email",
      "required": true,
      "input_type": "email"
    },
    {
      "name": "langfuse_admin_password",
      "type": "string",
      "description": "Langfuse admin password",
      "required": true,
      "input_type": "password"
    },
    {
      "name": "environment",
      "type": "string",
      "description": "Deployment environment",
      "required": false,
      "default": "dev"
    },
    {
      "name": "vpc_cidr",
      "type": "string",
      "description": "VPC CIDR block",
      "required": false,
      "default": "10.0.0.0/16"
    },
    {
      "name": "existing_vpc_id",
      "type": "string",
      "description": "Existing VPC ID to reuse (leave empty to create new)",
      "required": false,
      "default": ""
    }
  ],
  "outputs": {
    "langfuse_host": "Langfuse server URL",
    "langfuse_secret_name": "Secrets Manager secret name containing Langfuse API keys",
    "vpc_id": "VPC identifier",
    "private_subnet_ids": "Comma-separated private subnet IDs",
    "security_group_id": "Default security group ID"
  },
  "dependencies": [],
  "resources": [
    {
      "name": "ECS Fargate (Langfuse + Worker)",
      "description": "Langfuse v3 web app and background worker"
    },
    {
      "name": "Aurora PostgreSQL",
      "description": "Managed database for Langfuse"
    },
    {
      "name": "ClickHouse",
      "description": "Analytics database for trace storage"
    },
    {
      "name": "ElastiCache Redis",
      "description": "Caching and session management"
    },
    {
      "name": "CloudFront + ALB",
      "description": "CDN and load balancer"
    },
    {
      "name": "VPC + Networking",
      "description": "VPC, subnets, NAT, security groups"
    },
    {
      "name": "ECR Repositories",
      "description": "Container registries for images"
    },
    {
      "name": "Secrets Manager",
      "description": "Database credentials and secrets"
    }
  ],
  "learn_more": [
    {
      "title": "Langfuse Self-Hosting Documentation",
      "url": "https://langfuse.com/docs/deployment/self-host"
    },
    {
      "title": "Strands: Observability Tutorial",
      "url": "https://github.com/strands-agents/samples/tree/main/python/01-learn/08-observability"
    },
    {
      "title": "AgentCore: Observability Integrations",
      "url": "https://github.com/awslabs/agentcore-samples/tree/main/03-integrations/observability"
    }
  ],
  "jobs": [
    {
      "name": "onboarding",
      "incoming_event": "foundation_onboarding_request",
      "outgoing_event": "foundation_onboarding_success"
    },
    {
      "name": "offboarding",
      "incoming_event": "foundation_offboarding_request",
      "outgoing_event": "foundation_offboarding_success"
    }
  ],
  "hidden": true
}