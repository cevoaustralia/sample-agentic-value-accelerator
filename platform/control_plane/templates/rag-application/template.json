{
  "id": "rag-application",
  "name": "RAG Application",
  "description": "A Retrieval Augmented Generation (RAG) application that combines vector search with LLM generation to build knowledge-based AI systems. Query your documents, retrieve relevant context, and generate accurate, grounded responses.",
  "version": "1.0.0",
  "pattern_type": "rag",
  "frameworks": [
    {
      "id": "langraph",
      "name": "LangChain + LangGraph",
      "path": "src/langraph",
      "description": "LangGraph framework with LangChain integration for RAG pipelines"
    }
  ],
  "deployment_patterns": [
    {
      "id": "terraform",
      "name": "Terraform",
      "description": "Infrastructure as Code using Terraform for AWS deployment",
      "path": "iac/terraform"
    }
  ],
  "parameters": [
    {
      "name": "project_name",
      "type": "string",
      "description": "Name of your project (lowercase, alphanumeric, hyphens only)",
      "required": true,
      "pattern": "^[a-z][a-z0-9-]{2,49}$"
    },
    {
      "name": "aws_region",
      "type": "string",
      "description": "AWS region for deployment",
      "required": false,
      "default": "us-east-1",
      "enum": [
        "us-east-1",
        "us-east-2",
        "us-west-1",
        "us-west-2",
        "eu-west-1",
        "eu-central-1"
      ]
    },
    {
      "name": "vector_store",
      "type": "string",
      "description": "Vector store backend (opensearch, pinecone, pgvector)",
      "required": false,
      "default": "opensearch",
      "enum": [
        "opensearch",
        "pinecone",
        "pgvector"
      ]
    },
    {
      "name": "embedding_model",
      "type": "string",
      "description": "Embedding model for vector generation",
      "required": false,
      "default": "amazon.titan-embed-text-v1",
      "enum": [
        "amazon.titan-embed-text-v1",
        "amazon.titan-embed-text-v2:0",
        "cohere.embed-english-v3"
      ]
    },
    {
      "name": "chunk_size",
      "type": "integer",
      "description": "Document chunk size for processing",
      "required": false,
      "default": 1000,
      "minimum": 100,
      "maximum": 4000
    },
    {
      "name": "langfuse_host",
      "type": "string",
      "description": "Langfuse server endpoint URL",
      "required": false,
      "default": "https://cloud.langfuse.com"
    },
    {
      "name": "langfuse_secret_name",
      "type": "string",
      "description": "Secrets Manager secret name for Langfuse API keys",
      "required": false,
      "default": ""
    },
    {
      "name": "llm_model",
      "type": "string",
      "description": "LLM model for the agent",
      "required": false,
      "default": "anthropic.claude-haiku-4-5-20251001-v1:0",
      "enum": [
        "anthropic.claude-haiku-4-5-20251001-v1:0",
        "anthropic.claude-3-5-sonnet-20241022-v2:0",
        "anthropic.claude-3-haiku-20240307-v1:0",
        "amazon.nova-pro-v1:0",
        "amazon.nova-lite-v1:0"
      ]
    }
  ],
  "example_use_cases": [
    "Knowledge base Q&A systems",
    "Document-grounded chatbots",
    "Enterprise search applications",
    "Technical documentation assistants",
    "Customer support knowledge systems",
    "Research paper analysis tools"
  ],
  "author": "AVA Team",
  "license": "Apache-2.0",
  "tags": [
    "rag",
    "retrieval",
    "vector-search",
    "knowledge-base",
    "langchain",
    "embeddings"
  ],
  "type": "usecase",
  "outputs": {
    "api_endpoint": "RAG API endpoint",
    "knowledge_base_id": "Knowledge base identifier"
  },
  "jobs": [
    {
      "name": "onboarding",
      "incoming_event": "rag_app_onboarding_request",
      "outgoing_event": "rag_app_onboarding_success"
    },
    {
      "name": "offboarding",
      "incoming_event": "rag_app_offboarding_request",
      "outgoing_event": "rag_app_offboarding_success"
    }
  ],
  "dependencies": [
    "foundation-stack"
  ]
}