# =============================================================================
# Agent Runtime — AgentCore
# Copy this file to terraform.tfvars and edit the values.
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

project_name        = "my-agent"
aws_region          = "us-east-1"
container_image_uri = "123456789012.dkr.ecr.us-east-1.amazonaws.com/my-agent:v1.0.0"

# -----------------------------------------------------------------------------
# Runtime Configuration
# -----------------------------------------------------------------------------

# environment         = "dev"
# runtime_description = "My agent runtime"
# server_protocol     = "HTTP"    # HTTP, MCP, or A2A

# environment_variables = {
#   LOG_LEVEL  = "INFO"
#   MODEL_ID   = "anthropic.claude-sonnet-4-20250514"
# }

# -----------------------------------------------------------------------------
# Session Lifecycle
# -----------------------------------------------------------------------------

# idle_session_timeout = 300    # 5 minutes
# max_session_lifetime = 3600   # 1 hour

# -----------------------------------------------------------------------------
# Network — set to VPC for private networking
# -----------------------------------------------------------------------------

# network_mode           = "PUBLIC"
# vpc_subnet_ids         = ["subnet-abc123", "subnet-def456"]
# vpc_security_group_ids = ["sg-abc123"]

# -----------------------------------------------------------------------------
# Model Access
# -----------------------------------------------------------------------------

# model_id = "anthropic.claude-sonnet-4-20250514"

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------

# log_retention_days = 30

# -----------------------------------------------------------------------------
# Tags
# -----------------------------------------------------------------------------

# tags = {
#   Team  = "platform"
#   Owner = "jane@example.com"
# }
