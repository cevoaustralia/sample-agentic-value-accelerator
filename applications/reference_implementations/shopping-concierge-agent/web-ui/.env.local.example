# Web UI Environment Variables Configuration
# Copy this file to .env.local and update with your values

# ===== Agent Runtime Configuration =====
VITE_AGENT_RUNTIME_ARN=your-agent-runtime-arn-here
VITE_AGENT_ENDPOINT_NAME=DEFAULT

# ===== AWS Region =====
VITE_AWS_REGION=us-east-1

# ===== Cognito Configuration =====
# These are auto-populated by setup-web-ui-env.js from Amplify outputs
VITE_USER_POOL_ID=your-user-pool-id
VITE_USER_POOL_CLIENT_ID=your-client-id

# ===== Payment Integration Configuration =====
# Mock mode - uses frontend mock service for payment APIs
# All payment API calls return simulated data, no backend server needed
VITE_PAYMENT_MOCK_MODE=true

# ===== Knowledge Base (Optional) =====
# VITE_KNOWLEDGE_BASE_ID=your-kb-id
# VITE_DOCUMENTS_BUCKET=your-documents-bucket
