# Backend config files (contain account-specific identifiers)
backend.hcl

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI config file
.terraformrc
terraform.rc

# Note: .terraform.lock.hcl should be committed for reproducible builds

